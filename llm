#!/usr/bin/env bash
set -euo pipefail

LLM_DIR="$HOME/Documents/work/ai/local-llm"
MODEL_DIR="$LLM_DIR/models"
PIDFILE="$LLM_DIR/.llm-server.pid"
LOGFILE="$LLM_DIR/.llm-server.log"
RUNTIME_LOGFILE="$LLM_DIR/.llama-server-runtime.log"
STATEFILE="$LLM_DIR/.llm-server.state"
UNIT_NAME="qwen36-q6-maxctx"
UNIT="$UNIT_NAME.scope"
PROXY_UNIT_NAME="go-llm-proxy"
PROXY_UNIT="$PROXY_UNIT_NAME.service"
OLD_UNIT="local-llm-server.service"
PROXY_CONFIG="$LLM_DIR/proxy/go-llm-proxy.yaml"
PROXY_BIN="$LLM_DIR/references/go-llm-proxy/go-llm-proxy"
PROXY_PORT="8110"

STABLE_ENGINE="$LLM_DIR/engine/stable/llama.cpp/build/bin"
DEV_ENGINE="$LLM_DIR/engine/dev/llama.cpp/build/bin"

declare -A TIER_MODEL=(
  [default]="Qwen3.6-35B-A3B-UD-Q6_K_XL.gguf"
)

declare -A TIER_PORT=(
  [default]="8100"
)

declare -A TIER_FLAGS=(
  [default]="-ngl 99 -ot blk\.([3-9]|1[3-9]|2[2-9]|3[0-9])\.ffn_.*_exps\.weight=CPU --no-mmap -np 1 --cache-ram 512 --checkpoint-every-n-tokens 65536 --ctx-checkpoints 16 --no-cache-idle-slots -c 131072 --jinja --reasoning off"
)

# TODO: add an interactive "fast but dumb" tier once there is a model worth
# keeping operationally. For now the CLI intentionally exposes only the
# Qwen3.6 Q6 operational workhorse.

red()    { printf '\033[0;31m%s\033[0m\n' "$*"; }
green()  { printf '\033[0;32m%s\033[0m\n' "$*"; }
yellow() { printf '\033[0;33m%s\033[0m\n' "$*"; }
dim()    { printf '\033[0;90m%s\033[0m\n' "$*"; }

get_pid() {
  local main_pid
  main_pid=$(systemctl --user show "$UNIT" -p MainPID --value 2>/dev/null || true)
  if [[ -n "$main_pid" && "$main_pid" != "0" ]]; then
    echo "$main_pid"
  elif pgrep -f "$LLM_DIR/engine/.*/llama-server.*${TIER_MODEL[default]}" >/dev/null 2>&1; then
    pgrep -f "$LLM_DIR/engine/.*/llama-server.*${TIER_MODEL[default]}" | head -1
  elif [[ -f "$PIDFILE" ]]; then
    cat "$PIDFILE"
  else
    echo ""
  fi
}

is_running() {
  local pid
  pid=$(get_pid)
  [[ -n "$pid" ]] && process_running "$pid"
}

process_running() {
  local pid="$1"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null || return 1

  # Treat zombies as stopped. kill -0 stays true for zombies until reaped,
  # but they no longer hold the port or GPU memory.
  if [[ -r "/proc/$pid/stat" ]]; then
    local state
    state=$(awk '{print $3}' "/proc/$pid/stat" 2>/dev/null || true)
    [[ "$state" != "Z" ]]
  fi
}

get_engine_dir() {
  local engine="${1:-stable}"
  if [[ "$engine" == "dev" ]]; then
    echo "$DEV_ENGINE"
  else
    echo "$STABLE_ENGINE"
  fi
}

wait_for_port_down() {
  local port="$1" timeout=30 elapsed=0
  while (( elapsed < timeout )); do
    if ! curl -sf "http://localhost:$port/health" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
    (( elapsed++ ))
  done
  return 1
}

wait_for_ready() {
  local port="$1" model="$2" pid="$3" timeout=180 elapsed=0
  while (( elapsed < timeout )); do
    if ! process_running "$pid"; then
      return 1
    fi
    if curl -sf "http://localhost:$port/health" >/dev/null 2>&1; then
      if command -v jq >/dev/null 2>&1; then
        if curl -sf "http://localhost:$port/props" | jq -e --arg model "$model" '.model_path == $model and (.total_slots // 0) > 0' >/dev/null 2>&1; then
          return 0
        fi
      else
        if curl -sf "http://localhost:$port/props" | grep -F "\"model_path\":\"$model\"" >/dev/null 2>&1; then
          return 0
        fi
      fi
    fi
    sleep 1
    (( elapsed++ ))
  done
  return 1
}

wait_for_proxy_down() {
  local timeout=10 elapsed=0
  while (( elapsed < timeout )); do
    if ! curl -sf "http://localhost:$PROXY_PORT/v1/models" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
    (( elapsed++ ))
  done
  return 1
}

start_proxy() {
  if [[ ! -x "$PROXY_BIN" ]]; then
    red "go-llm-proxy binary not found: $PROXY_BIN"
    echo "Build it with: make -C $LLM_DIR/references/go-llm-proxy build"
    exit 1
  fi

  if [[ ! -f "$PROXY_CONFIG" ]]; then
    red "go-llm-proxy config not found: $PROXY_CONFIG"
    exit 1
  fi

  systemctl --user kill --kill-whom=all --signal=KILL "$PROXY_UNIT" 2>/dev/null || true
  systemctl --user reset-failed "$PROXY_UNIT" 2>/dev/null || true
  wait_for_proxy_down || {
    red "Proxy port $PROXY_PORT is still serving after stop; refusing to start a second proxy"
    exit 1
  }

  systemd-run --user \
    --expand-environment=no \
    --unit="$PROXY_UNIT_NAME" \
    -p KillSignal=SIGKILL \
    -p SendSIGKILL=yes \
    -p TimeoutStopSec=2s \
    "$PROXY_BIN" -config "$PROXY_CONFIG"
}

cmd_stop() {
  systemctl --user kill --kill-whom=all --signal=KILL "$PROXY_UNIT" 2>/dev/null || true
  systemctl --user reset-failed "$PROXY_UNIT" 2>/dev/null || true

  # Clean up old manual tuning scopes too, so `llm stop` unloads anything this
  # repo started during the Qwen3.6 experiments.
  systemctl --user kill --kill-whom=all --signal=KILL "$UNIT" 2>/dev/null || true
  systemctl --user reset-failed "$UNIT" 2>/dev/null || true
  systemctl --user stop "$OLD_UNIT" 2>/dev/null || true
  systemctl --user reset-failed "$OLD_UNIT" 2>/dev/null || true

  if is_running; then
    local pid
    pid=$(get_pid)
    kill "$pid" 2>/dev/null || true
    local waited=0
    while process_running "$pid" && (( waited < 20 )); do
      sleep 1
      (( waited++ ))
    done
    if process_running "$pid"; then
      kill -9 "$pid" 2>/dev/null
      waited=0
      while process_running "$pid" && (( waited < 5 )); do
        sleep 1
        (( waited++ ))
      done
    fi
    rm -f "$PIDFILE"
    green "Stopped LLM server (pid $pid)"
  else
    rm -f "$PIDFILE"
    dim "No LLM server running"
  fi
}

cmd_status() {
  if is_running; then
    local pid
    pid=$(get_pid)
    local tier_info engine_info
    tier_info=$(head -1 "$LOGFILE" 2>/dev/null || echo "unknown")
    engine_info=$(cat "$STATEFILE" 2>/dev/null || echo "unknown")
    green "LLM server running (pid $pid)"
    echo "$tier_info"
    dim "Engine: $engine_info"
    systemctl --user show "$UNIT" -p MemoryCurrent -p MemoryPeak -p MemoryHigh -p MemoryMax -p MemorySwapCurrent -p MemorySwapMax 2>/dev/null | \
      awk -F= '
        $1=="MemoryCurrent"{cur=$2}
        $1=="MemoryPeak"{peak=$2}
        $1=="MemoryHigh"{high=$2}
        $1=="MemoryMax"{max=$2}
        $1=="MemorySwapCurrent"{swap=$2}
        $1=="MemorySwapMax"{swapmax=$2}
        END {
          if (cur != "") {
            printf "Memory: current=%s peak=%s high=%s max=%s swap=%s swapmax=%s bytes\n", cur, peak, high, max, swap, swapmax
          }
        }'
    if command -v nvidia-smi &>/dev/null; then
      nvidia-smi --query-gpu=memory.used,memory.total --format=csv,noheader,nounits | \
        awk -F', ' '{printf "VRAM: %s / %s MB\n", $1, $2}'
    fi
    if curl -sf "http://localhost:$PROXY_PORT/v1/models" >/dev/null 2>&1; then
      green "LLM proxy running on http://127.0.0.1:$PROXY_PORT/v1"
    else
      yellow "LLM proxy is not responding on port $PROXY_PORT"
    fi
  else
    rm -f "$PIDFILE"
    dim "No LLM server running"
  fi
}

cmd_start() {
  local tier="$1"
  shift

  if [[ -z "${TIER_MODEL[$tier]+x}" ]]; then
    red "Unknown tier: $tier"
    echo "Available: default"
    exit 1
  fi

  # Parse --dev flag from remaining args
  local engine="stable"
  local extra_flags=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dev) engine="dev"; shift ;;
      *) extra_flags+=("$1"); shift ;;
    esac
  done

  local engine_dir
  engine_dir=$(get_engine_dir "$engine")
  local model="$MODEL_DIR/${TIER_MODEL[$tier]}"
  local port="${TIER_PORT[$tier]}"
  local server="$engine_dir/llama-server"

  if [[ ! -f "$model" ]]; then
    red "Model not found: $model"
    echo "Download it to $MODEL_DIR/"
    exit 1
  fi

  if [[ ! -f "$server" ]]; then
    red "llama-server not found: $server"
    echo "Build llama.cpp first in engine/$engine/"
    exit 1
  fi

  cmd_stop
  if ! wait_for_port_down "$port"; then
    red "Port $port is still serving after stop; refusing to start a second server"
    exit 1
  fi

  local default_flags="${TIER_FLAGS[$tier]}"
  local override_flags="${extra_flags[*]:-}"
  local final_flags="$default_flags"

  if [[ -n "$override_flags" ]]; then
    local -a override_arr=($override_flags)
    local i=0
    while (( i < ${#override_arr[@]} )); do
      local flag="${override_arr[$i]}"
      if [[ "$flag" == -* ]]; then
        local value=""
        if (( i + 1 < ${#override_arr[@]} )) && [[ "${override_arr[$((i+1))]}" != -* ]]; then
          value="${override_arr[$((i+1))]}"
          final_flags=$(echo "$final_flags" | sed -E "s|${flag}[[:space:]]+[^-][^[:space:]]*||g")
          final_flags="$final_flags $flag $value"
          (( i += 2 ))
        else
          final_flags="$final_flags $flag"
          (( i++ ))
        fi
      else
        (( i++ ))
      fi
    done
  fi

  # Persist state
  echo "engine=$engine tier=$tier" > "$STATEFILE"

  echo "# tier=$tier engine=$engine model=$(basename "$model") port=$port $(date -Iseconds)" > "$LOGFILE"
  echo "# flags: $final_flags" >> "$LOGFILE"
  : > "$RUNTIME_LOGFILE"

  yellow "Starting $tier tier on port $port ($engine engine)..."
  dim "Model: $(basename "$model")"
  dim "Engine: $engine ($server)"
  dim "Flags: $final_flags"

  start_proxy

  # Match the manual, validated command shape exactly: a transient user scope,
  # hard cgroup limits, no cgroup swap, timeout wrapper, and core dumps disabled.
  source "$HOME/.config/cuda-env.sh" 2>/dev/null || true

  systemd-run --user \
    --scope \
    --expand-environment=no \
    --unit="$UNIT_NAME" \
    -p KillSignal=SIGKILL \
    -p SendSIGKILL=yes \
    -p TimeoutStopSec=2s \
    -p MemoryMax=30720M \
    -p MemoryHigh=28672M \
    -p MemorySwapMax=0 \
    timeout 60m \
    bash -lc 'ulimit -c 0; logfile="$1"; shift; "$@" 2>&1 | tee -a "$logfile"; exit "${PIPESTATUS[0]}"' bash \
    "$RUNTIME_LOGFILE" "$server" -m "$model" --port "$port" --host 0.0.0.0 $final_flags
}

cmd_bench() {
  local model="$1"
  shift
  local engine_dir
  engine_dir=$(get_engine_dir "stable")
  local bench="$engine_dir/llama-bench"

  if [[ ! -f "$bench" ]]; then
    red "llama-bench not found. Build llama.cpp first."
    exit 1
  fi

  if [[ ! -f "$model" ]] && [[ -f "$MODEL_DIR/$model" ]]; then
    model="$MODEL_DIR/$model"
  fi

  local timestamp basename outfile
  timestamp=$(date +%Y-%m-%d-%H%M)
  basename=$(basename "$model" .gguf)
  outfile="$LLM_DIR/benchmarks/${timestamp}-${basename}.txt"

  yellow "Benchmarking $(basename "$model")..."
  $bench -m "$model" -ngl 99 -fa 1 "$@" | tee "$outfile"
  green "Saved to $outfile"
}

cmd_bench_parallel() {
  local model="$1"
  shift
  local engine_dir
  engine_dir=$(get_engine_dir "stable")
  local bench="$engine_dir/llama-batched-bench"

  if [[ ! -f "$bench" ]]; then
    red "llama-batched-bench not found. Build llama.cpp first."
    exit 1
  fi

  if [[ ! -f "$model" ]] && [[ -f "$MODEL_DIR/$model" ]]; then
    model="$MODEL_DIR/$model"
  fi

  local timestamp basename outfile
  timestamp=$(date +%Y-%m-%d-%H%M)
  basename=$(basename "$model" .gguf)
  outfile="$LLM_DIR/benchmarks/${timestamp}-${basename}-parallel.txt"

  yellow "Parallel benchmarking $(basename "$model")..."
  $bench -m "$model" -ngl 99 -fa 1 \
    -c 32768 -b 2048 -ub 512 \
    -npp 512,2048 -ntg 128,512 -npl 1,2,4,8 \
    "$@" | tee "$outfile"
  green "Saved to $outfile"
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  start)
    tier="default"
    if [[ "$#" -gt 0 && "$1" != --* ]]; then
      tier="$1"
      shift || true
    fi
    cmd_start "$tier" "$@"
    ;;
  stop)
    cmd_stop
    ;;
  status)
    cmd_status
    ;;
  bench)
    model="${1:-}"
    shift || true
    if [[ -z "$model" ]]; then
      red "Usage: llm bench <model.gguf> [extra flags...]"
      exit 1
    fi
    cmd_bench "$model" "$@"
    ;;
  bench-parallel)
    model="${1:-}"
    shift || true
    if [[ -z "$model" ]]; then
      red "Usage: llm bench-parallel <model.gguf> [extra flags...]"
      exit 1
    fi
    cmd_bench_parallel "$model" "$@"
    ;;
  help|--help|-h)
    cat <<'HELP'
llm — local LLM server manager

Commands:
  start [--dev] [flags...]           Start the default Qwen3.6 Q6 workhorse
                                     and local go-llm-proxy on port 8110
                                     --dev uses the dev engine (fork with PRs)
                                     Extra flags override defaults
  stop                               Stop the running server and proxy
  status                             Show what's running + proxy + VRAM usage

  bench <model> [flags...]           Single-stream benchmark
  bench-parallel <model> [flags...]  Parallel scaling benchmark (1,2,4,8)

Default:
  Qwen3.6 35B Q6, 131K ctx, no mmap, 8 GPU expert layers, 512/65536/16 prompt cache

Engines:
  stable (default)  tracks ggml-org/llama.cpp main, auto-rebuilt daily
  dev (--dev)       VisarDomi/llama.cpp fork, cherry-picked PRs

Examples:
  llm start
  llm status
  llm stop
HELP
    ;;
  *)
    red "Unknown command: $cmd"
    echo "Run 'llm help' for usage"
    exit 1
    ;;
esac
